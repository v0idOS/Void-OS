<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VoidControlCenter.Views.PerformancePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctk="using:CommunityToolkit.WinUI.Controls"
    RequestedTheme="Dark"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="24" Padding="40,32,40,40">

            <StackPanel Spacing="4">
                <TextBlock Text="PERFORMANCE" FontSize="11" FontWeight="SemiBold"
                           Foreground="#1a3aff" CharacterSpacing="200"/>
                <TextBlock Text="Kernel Tuning" FontSize="28"
                           FontFamily="Segoe UI Variable Display" FontWeight="SemiBold"/>
                <TextBlock Text="Hardware-gated tweaks. IRQ/NDIS/ASPM only activate on compatible Intel Hybrid platforms."
                           FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- CPU Scheduling -->
            <ctk:SettingsExpander Header="CPU Scheduler" Description="Win32PrioritySeparation and Thread Director compensation"
                                  IsExpanded="True">
                <ctk:SettingsExpander.HeaderIcon>
                    <FontIcon Glyph="&#xE950;"/>
                </ctk:SettingsExpander.HeaderIcon>
                <ctk:SettingsExpander.Items>
                    <ctk:SettingsCard Header="Win32PrioritySeparation Override"
                                      Description="Rewrites the kernel scheduling quantum to maximize foreground responsiveness. 0x28 on Intel Hybrid CPUs, 0x26 on Classic.">
                        <ctk:SettingsCard.HeaderIcon><FontIcon Glyph="&#xE945;"/></ctk:SettingsCard.HeaderIcon>
                        <Border Background="#0d1a3a" CornerRadius="4" Padding="8,4">
                            <TextBlock x:Name="txtPriority" Text="Reading..." FontFamily="Consolas" FontSize="12" Foreground="#1a3aff"/>
                        </Border>
                    </ctk:SettingsCard>
                    <ctk:SettingsCard Header="CPU Mitigations (Spectre/Meltdown)"
                                      Description="Disabled for maximum IPC throughput. Do not re-enable on shared or work machines.">
                        <ctk:SettingsCard.HeaderIcon><FontIcon Glyph="&#xE7BA;"/></ctk:SettingsCard.HeaderIcon>
                        <Border Background="#1a0d0d" CornerRadius="4" Padding="8,4">
                            <TextBlock Text="ANNIHILATED" FontFamily="Consolas" FontSize="12" Foreground="#ff3a3a"/>
                        </Border>
                    </ctk:SettingsCard>
                </ctk:SettingsExpander.Items>
            </ctk:SettingsExpander>

            <!-- Interrupt Routing -->
            <ctk:SettingsExpander Header="Interrupt Routing" Description="IRQ affinity pinning and NDIS RSS — Intel Hybrid only"
                                  IsExpanded="True">
                <ctk:SettingsExpander.HeaderIcon>
                    <FontIcon Glyph="&#xE7F4;"/>
                </ctk:SettingsExpander.HeaderIcon>
                <ctk:SettingsExpander.Items>
                    <ctk:SettingsCard Header="GPU IRQ Affinity (P-Core 1)"
                                      Description="Pins NVIDIA GPU interrupt queue to P-Core 1 (mask 0x02). Isolates dxgkrnl.sys scheduling from background noise.">
                        <ctk:SettingsCard.HeaderIcon><FontIcon Glyph="&#xE7F4;"/></ctk:SettingsCard.HeaderIcon>
                        <Border Background="#0d1a3a" CornerRadius="4" Padding="8,4">
                            <TextBlock Text="MASK 0x02" FontFamily="Consolas" FontSize="12" Foreground="#1a3aff"/>
                        </Border>
                    </ctk:SettingsCard>
                    <ctk:SettingsCard Header="NDIS RSS — E-Core Offload"
                                      Description="Routes all network packet processing to E-Cores (BaseProcessor 4, Max 4). Frees P-Cores for rendering exclusively.">
                        <ctk:SettingsCard.HeaderIcon><FontIcon Glyph="&#xE701;"/></ctk:SettingsCard.HeaderIcon>
                        <Border Background="#0d1a3a" CornerRadius="4" Padding="8,4">
                            <TextBlock Text="E-CORES ONLY" FontFamily="Consolas" FontSize="12" Foreground="#1a3aff"/>
                        </Border>
                    </ctk:SettingsCard>
                    <ctk:SettingsCard Header="NVMe + Network IRQ (E-Cores)"
                                      Description="Storage and network adapter interrupts pinned to E-Core cluster (mask 0xF0) via PCI registry injection.">
                        <ctk:SettingsCard.HeaderIcon><FontIcon Glyph="&#xEDA2;"/></ctk:SettingsCard.HeaderIcon>
                        <Border Background="#0d1a3a" CornerRadius="4" Padding="8,4">
                            <TextBlock Text="MASK 0xF0" FontFamily="Consolas" FontSize="12" Foreground="#1a3aff"/>
                        </Border>
                    </ctk:SettingsCard>
                </ctk:SettingsExpander.Items>
            </ctk:SettingsExpander>

            <!-- Latency -->
            <ctk:SettingsExpander Header="Latency Engine" Description="DPC spike reduction and PCIe bus tuning"
                                  IsExpanded="True">
                <ctk:SettingsExpander.HeaderIcon>
                    <FontIcon Glyph="&#xEC7A;"/>
                </ctk:SettingsExpander.HeaderIcon>
                <ctk:SettingsExpander.Items>
                    <ctk:SettingsCard Header="PCIe ASPM Disabled"
                                      Description="Stops ACPI.sys from polling PCIe link state. Reduced worst DPC spike from 1500μs → 629μs. Safe on laptops — does not break battery or sleep.">
                        <ctk:SettingsCard.HeaderIcon><FontIcon Glyph="&#xE945;"/></ctk:SettingsCard.HeaderIcon>
                        <Border Background="#0d1a3a" CornerRadius="4" Padding="8,4">
                            <TextBlock Text="629μs MAX" FontFamily="Consolas" FontSize="12" Foreground="#1a3aff"/>
                        </Border>
                    </ctk:SettingsCard>
                    <ctk:SettingsCard Header="MMIO USWC Write-Combining"
                                      Description="CPU batches writes to GPU VRAM in cache-line bursts instead of stalling on each write. Reduces CPU stall time during draw call submission.">
                        <ctk:SettingsCard.HeaderIcon><FontIcon Glyph="&#xE7F4;"/></ctk:SettingsCard.HeaderIcon>
                        <Border Background="#0d1a3a" CornerRadius="4" Padding="8,4">
                            <TextBlock Text="USWC ACTIVE" FontFamily="Consolas" FontSize="12" Foreground="#1a3aff"/>
                        </Border>
                    </ctk:SettingsCard>
                    <ctk:SettingsCard Header="HPET Disabled / TSC Sync Enhanced"
                                      Description="Forces hardware TSC timer via bcdedit. Eliminates timer interrupt overhead. disabledynamictick=yes, tscsyncpolicy=Enhanced.">
                        <ctk:SettingsCard.HeaderIcon><FontIcon Glyph="&#xE916;"/></ctk:SettingsCard.HeaderIcon>
                        <Border Background="#0d1a3a" CornerRadius="4" Padding="8,4">
                            <TextBlock Text="TSC ENFORCED" FontFamily="Consolas" FontSize="12" Foreground="#1a3aff"/>
                        </Border>
                    </ctk:SettingsCard>
                </ctk:SettingsExpander.Items>
            </ctk:SettingsExpander>

        </StackPanel>
    </ScrollViewer>
</Page>
