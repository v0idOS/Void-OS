<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VoidControlCenter.Views.ToolsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctk="using:CommunityToolkit.WinUI.Controls"
    RequestedTheme="Dark"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="24" Padding="40,32,40,40">

            <StackPanel Spacing="4">
                <TextBlock Text="TOOLS" FontSize="11" FontWeight="SemiBold"
                           Foreground="#1a3aff" CharacterSpacing="200"/>
                <TextBlock Text="Void Toolkit" FontSize="28"
                           FontFamily="Segoe UI Variable Display" FontWeight="SemiBold"/>
                <TextBlock Text="One-click maintenance and system access."
                           FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <ctk:SettingsCard Header="Flush Standby Memory"
                              Description="Immediately purges the standby memory list via NtSetSystemInformation. Run before starting a gaming session for minimum memory stall latency.">
                <ctk:SettingsCard.HeaderIcon><FontIcon Glyph="&#xE74D;"/></ctk:SettingsCard.HeaderIcon>
                <Button x:Name="btnFlush" Content="Flush Memory" Click="BtnFlush_Click"
                        Style="{StaticResource AccentButtonStyle}"/>
            </ctk:SettingsCard>

            <ctk:SettingsCard Header="Reset Network to Void Defaults"
                              Description="Reapplies Void network adapter settings. Run after installing new network drivers or Windows updates that may reset adapter registry keys.">
                <ctk:SettingsCard.HeaderIcon><FontIcon Glyph="&#xE72C;"/></ctk:SettingsCard.HeaderIcon>
                <Button x:Name="btnNetwork" Content="Reset Network" Click="BtnNetwork_Click"/>
            </ctk:SettingsCard>

            <ctk:SettingsCard Header="Create System Restore Point"
                              Description="Manually create a restore point before applying experimental tweaks or installing drivers.">
                <ctk:SettingsCard.HeaderIcon><FontIcon Glyph="&#xE777;"/></ctk:SettingsCard.HeaderIcon>
                <Button x:Name="btnRestore" Content="Create Restore Point" Click="BtnRestore_Click"/>
            </ctk:SettingsCard>

            <ctk:SettingsCard Header="Open VoidDesktop Folder"
                              Description="Opens C:\Windows\VoidDesktop — your post-install toolkit with reversal scripts, advanced configuration, and network tools.">
                <ctk:SettingsCard.HeaderIcon><FontIcon Glyph="&#xED25;"/></ctk:SettingsCard.HeaderIcon>
                <Button x:Name="btnDesktop" Content="Open Folder" Click="BtnDesktop_Click"/>
            </ctk:SettingsCard>

            <ctk:SettingsCard Header="View Engine Log"
                              Description="Opens the latest VoidOS Master Engine execution log from C:\VoidOS_Logs\">
                <ctk:SettingsCard.HeaderIcon><FontIcon Glyph="&#xE9F9;"/></ctk:SettingsCard.HeaderIcon>
                <Button x:Name="btnLog" Content="Open Log" Click="BtnLog_Click"/>
            </ctk:SettingsCard>

            <!-- Version Footer -->
            <Border Padding="0,16,0,0">
                <TextBlock Text="Void OS Control Center v1.0  ·  github.com/v0idOS/Void-OS"
                           FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           HorizontalAlignment="Center" FontFamily="Consolas"/>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
